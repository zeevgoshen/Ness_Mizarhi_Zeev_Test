@model List<Ness_Mizarhi_Zeev_Test.Core.Models.Operation>

@{
    var model = Model;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Todo Details</title>

    <link rel="stylesheet" href="~/css/index.css" />
</head>
<body>
    <form id="calcForm" onsubmit="return calculate(event)">
    <div class="form-container">

        <!-- Insert command -->
        <div class="row">
            <input type="button" value="Insert command" onclick="createOperator()" id="newOperatorBtn" />
            <input type="text" maxlength="5" id="newOperator" placeholder="Enter new operator..." />
            <input type="text" maxlength="20" id="operatorDescription" placeholder="Enter new operator description..." />
        </div>

        <!-- Main calculation row -->
        <div class="row">
            <label>Field A</label>
                <input type="text" inputmode="decimal" id="FieldA" required
                       oninput="this.setCustomValidity(''); limitLength(this, 15)"
                       oninvalid="this.setCustomValidity('Please enter a number')"
                       pattern="-?[0-9]+(\.[0-9]*)?" />

            <label>Operation</label>
            <select name="operationId" id="operations">
                @foreach (var op in Model)
                {
                    <option value="@op.OperationId">@op.Operator</option>
                }
            </select>

            <label>Field B</label>
                <input type="text" inputmode="decimal" id="FieldB" required
                       oninput="this.setCustomValidity(''); limitLength(this, 15)"
                       oninvalid="this.setCustomValidity('Please enter a number')"
                       pattern="-?[0-9]+(\.[0-9]*)?" />

            <input type="submit" value="Calculate" />
        </div>

        <!-- Result -->
        <div class="row">
            <label>Result</label>
            <textarea id="result" rows="3"></textarea>
        </div>

    </div>
    </form>
    <script src="~/js/index.js"></script>
</body>
</html>